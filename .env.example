# Local PostgreSQL connection string (required for npm run dev)
DATABASE_URL="postgresql://YOUR_USER@127.0.0.1:5432/actinium_dd?schema=public"

# Prisma Postgres on Vercel (auto-injected as PRISMA_DATABASE_URL).
# The app maps this to DATABASE_URL at runtime when DATABASE_URL is not set.
# PRISMA_DATABASE_URL="postgres://...@db.prisma.io:5432/postgres?sslmode=require"

# Public URL for yard invite links (production)
NEXT_PUBLIC_APP_URL="https://your-office-server.example.com"

# Session signing secret (required — use 32+ random characters in production)
OFFICE_AUTH_SECRET="random-32-char-secret-for-session-signing"

# Optional break-glass office password (legacy; employee login is the primary path)
# OFFICE_AUTH_PASSWORD="choose-a-strong-password"

# Session idle timeout in seconds (default: 1200 = 20 minutes)
# SESSION_IDLE_TIMEOUT_SEC=1200

# After `npm run db:seed`, sign in with:
#   Login ID: ACT.1001
#   Password: Admin@1001
#   Role ID:  1001 (SYS_ADMIN — System Administrator)

# Fleet local node (ship / superintendent desktop)
# FLEET_ORIGIN_NODE=ship
# VESSEL_ID=your-fleet-vessel-uuid
# FLEET_API_PORT=3847

# VPS relay (see docs/sync/relay-installation.local.env.example)
# OFFICE_DIRECT_DATABASE_URL=postgresql://...

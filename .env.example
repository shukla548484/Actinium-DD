# PostgreSQL connection string (required)
DATABASE_URL="postgresql://YOUR_USER@127.0.0.1:5432/actinium_dd?schema=public"

# Public URL for yard invite links (production)
NEXT_PUBLIC_APP_URL="https://your-office-server.example.com"

# Office portal authentication (Phase D)
# Leave OFFICE_AUTH_PASSWORD empty to disable auth (local dev only).
OFFICE_AUTH_PASSWORD="choose-a-strong-password"
OFFICE_AUTH_SECRET="random-32-char-secret-for-session-signing"

# Fleet local node (ship / superintendent desktop)
# FLEET_ORIGIN_NODE=ship
# VESSEL_ID=your-fleet-vessel-uuid
# FLEET_API_PORT=3847

# VPS relay (see docs/sync/relay-installation.local.env.example)
# OFFICE_DIRECT_DATABASE_URL=postgresql://...

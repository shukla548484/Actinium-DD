# VPS relay environment — copy to relay-installation.local.env (gitignored on VPS: /root/relay-installation.local.env)

# Office master PostgreSQL (direct connection, sslmode=require for hosted DBs)
OFFICE_DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@office-host:5432/actinium_dd?sslmode=require"

# Fleet vessel UUID — matches projects.vessel_id for relay scope
VESSEL_ID="your-fleet-vessel-uuid"

# Relay database name on VPS (default)
RELAY_DB="drydock_sync_relay"

# Overlap window for watermark-based sync (minutes)
SYNC_OVERLAP_MINUTES=15

# Optional TLS mode for psql
PGSSLMODE=require

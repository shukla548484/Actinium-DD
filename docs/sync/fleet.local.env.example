# Fleet node environment — copy to fleet.local.env (gitignored)

# Local PostgreSQL (docker-compose.fleet.yml default)
DATABASE_URL="postgresql://drydock:drydock_local@127.0.0.1:5434/actinium_dd?schema=public"

# Must match projects.vessel_id and VPS relay VESSEL_ID
VESSEL_ID="your-fleet-vessel-uuid"

# ship | superintendent
FLEET_ORIGIN_NODE=ship

# Fleet local API (Tauri desktop)
FLEET_API_PORT=3847
FLEET_API_HOST=127.0.0.1

# Bucardo / relay log paths (optional)
BUCARDO_LOG_PATH=/var/log/bucardo.log
RELAY_LOG_PATH=/var/log/drydock-relay-sync.log

# VPS relay (for Bucardo — ship/superintendent init)
RELAY_DATABASE_URL="postgresql://bucardo_drydock_fleet@YOUR_VPS:5432/drydock_sync_relay"
LOCAL_DATABASE_URL="postgresql://drydock:drydock_local@127.0.0.1:5434/actinium_dd"

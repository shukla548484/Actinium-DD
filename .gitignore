# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/desktop/dist
/desktop/src-tauri/target

# misc
.DS_Store
*.pem
/public/uploads/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local database
/data/

# legacy sqlite (removed)
*.db
*.db-journal
*.db-wal
*.db-shm

# local app runtime logs
local-apps/**/sidecar.log
local-apps/**/fleet.local.env

# built installers (copy via npm run local-app:package)
local-apps/mac/*.dmg
local-apps/mac/*.app
local-apps/windows/*.msi
local-apps/windows/*.exe

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

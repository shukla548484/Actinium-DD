/// 01_Master_Job_Library — 33 fields
model MasterJobLibrary {
  id                       String                @id @default(cuid())
  jobId                    String                @unique @map("job_id")
  libraryVersion           String                @map("library_version")
  department               JobCatalogDepartment
  systemGroup              String                @map("system_group")
  machinery                String
  component                String
  subComponent             String?               @map("sub_component")
  standardJobName          String                @map("standard_job_name")
  jobDescription           String                @map("job_description") @db.Text
  applicableVesselTypes    String[]              @default([]) @map("applicable_vessel_types")
  applicableProjectTypes   DryDockProjectType[]  @default([]) @map("applicable_project_types")
  surveyType               String?               @map("survey_type")
  workshop                 JobCatalogWorkshop
  responsibleUserRole      String                @map("responsible_user_role")
  reviewRole               String                @map("review_role")
  approvalRole             String                @map("approval_role")
  templateId               String                @map("template_id")
  measurementSetId         String?               @map("measurement_set_id")
  inspectionChecklistId    String?               @map("inspection_checklist_id")
  scopeOfWorkId            String?               @map("scope_of_work_id")
  rfqCategory              String                @map("rfq_category")
  budgetCategory           String                @map("budget_category")
  dryDockCostCode          String                @map("dry_dock_cost_code")
  mandatoryFlag            Boolean               @default(false) @map("mandatory_flag")
  classHoldPoint           Boolean               @default(false) @map("class_hold_point")
  makerAttendanceRequired  Boolean               @default(false) @map("maker_attendance_required")
  permitRequired           String[]              @default([]) @map("permit_required")
  photoRequired            Boolean               @default(false) @map("photo_required")
  attachmentRequired       Boolean               @default(false) @map("attachment_required")
  standardManHours         Float?                @map("standard_man_hours")
  riskLevel                DdRiskLevel           @map("risk_level")
  activeFlag               Boolean               @default(true) @map("active_flag")
  remarks                  String?               @db.Text
  jobLibraryNodeId         String?               @unique @map("job_library_node_id")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")

  template       JobDynamicTemplate   @relation(fields: [templateId], references: [templateId])
  jobLibraryNode JobLibraryNode?      @relation(fields: [jobLibraryNodeId], references: [id], onDelete: SetNull)
  spareMappings  JobSpareMapping[]
  rfqMappings    JobRfqBudgetMapping[]

  @@index([department])
  @@index([workshop])
  @@index([templateId])
  @@index([measurementSetId])
  @@index([inspectionChecklistId])
  @@index([scopeOfWorkId])
  @@index([activeFlag])
  @@map("master_job_library")
}

/// 02_Dynamic_Template_Library — 14 fields
model JobDynamicTemplate {
  id                  String              @id @default(cuid())
  templateId          String              @unique @map("template_id")
  templateName        String              @map("template_name")
  templateCategory    JobTemplateCategory @map("template_category")
  version             String
  formSections        Json                @map("form_sections")
  autoFillFields      Json                @map("auto_fill_fields")
  manualInputFields   Json                @map("manual_input_fields")
  requiredPhotos      Json                @map("required_photos")
  requiredAttachments Json                @map("required_attachments")
  measurementSetId    String?             @map("measurement_set_id")
  checklistId         String?             @map("checklist_id")
  approvalWorkflowId  String              @map("approval_workflow_id")
  uiLayoutType        JobUiLayoutType     @map("ui_layout_type")
  activeFlag          Boolean             @default(true) @map("active_flag")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  approvalWorkflow       JobApprovalWorkflow    @relation(fields: [approvalWorkflowId], references: [workflowId])
  masterJobs             MasterJobLibrary[]
  measurements           JobMeasurement[]
  checklistItems         JobChecklistItem[]

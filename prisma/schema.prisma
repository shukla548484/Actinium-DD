enum DdInputSubmissionStatus {
  draft
  submitted
  reviewed
  approved
  rejected
  inactive
}

enum DdInputResponsibleRole {
  vessel
  superintendent
  shipyard
  purchase
  class
  accounts
}

/// Structured project input — one active row per section per project (versioned via inactive + new draft).
model DdInputSubmission {
  id               String                   @id @default(cuid())
  dryDockProjectId String                   @map("dry_dock_project_id")
  sectionKey       String                   @map("section_key")
  pageKey          String                   @map("page_key")
  moduleId         String                   @map("module_id")
  version          Int                      @default(1)
  status           DdInputSubmissionStatus  @default(draft)
  valuesJson       Json                     @default("{}") @map("values_json")
  enteredByRole    DdInputResponsibleRole   @map("entered_by_role")
  enteredByName    String?                  @map("entered_by_name")
  enteredAt        DateTime?                @map("entered_at")
  reviewedByName   String?                  @map("reviewed_by_name")
  reviewedAt       DateTime?                @map("reviewed_at")
  reviewNotes      String?                  @map("review_notes")
  approvedByName   String?                  @map("approved_by_name")
  approvedAt       DateTime?                @map("approved_at")
  linkedJobId      String?                  @map("linked_job_id")
  mandatory        Boolean                  @default(false)
  attachmentRequired Boolean                @default(false) @map("attachment_required")
  deletedAt        DateTime?                @map("deleted_at")
  inactiveAt       DateTime?                @map("inactive_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  dryDockProject DryDockProject @relation(fields: [dryDockProjectId], references: [id], onDelete: Cascade)

  @@index([dryDockProjectId, sectionKey])
  @@index([dryDockProjectId, pageKey])
  @@index([status])
  @@index([deletedAt])
  @@map("dd_input_submissions")
}

  enteredByName    String?                  @map("entered_by_name")
  enteredAt        DateTime?                @map("entered_at")
  reviewedByName   String?                  @map("reviewed_by_name")
  reviewedAt       DateTime?                @map("reviewed_at")
  reviewNotes      String?                  @map("review_notes")
  approvedByName   String?                  @map("approved_by_name")
  approvedAt       DateTime?                @map("approved_at")
  linkedJobId      String?                  @map("linked_job_id")
  mandatory        Boolean                  @default(false)
  attachmentRequired Boolean                @default(false) @map("attachment_required")
  deletedAt        DateTime?                @map("deleted_at")
  inactiveAt       DateTime?                @map("inactive_at")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")


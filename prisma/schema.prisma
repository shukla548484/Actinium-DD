generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  tendering
  comparing
  closed
}

enum YardInviteStatus {
  invited
  in_progress
  submitted
  excel_imported
  shortlisted
  accepted
  rejected
}

enum QuoteSource {
  portal
  excel
}

enum PricingStatus {
  priced
  included
  na
  owner_supply
}

enum MatchMethod {
  portal
  excel_auto
  excel_manual
  owner
}

enum ScopeLocale {
  en
  zh
  ja
}

/// Which node last wrote or owns a row for sync conflict rules.
enum SyncOriginNode {
  office
  vps
  ship
  superintendent
  yard
}

/// RBAC — where the user operates (matches role spreadsheet User Type).
enum RbacUserType {
  system
  office
  vessel
  external
}

enum UserStatus {
  active
  invited
  disabled
}

/// Scope for a role assignment (vessel, project, yard invite, etc.).
enum RbacScopeType {
  system
  organization
  fleet
  vessel
  project
  yard_invite
}

/// Application surface for page-level access control.
enum AppSurface {
  office
  desktop
  yard
  vessel
  platform
}

enum EntityStatus {
  active
  wait
  inactive
}

enum CompanyType {
  MASTER
  SUB
}

enum CompanyCategory {
  shipyard
  ship_management
  ship_owner
  other
}

model Company {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  type            CompanyType      @default(MASTER)
  category        CompanyCategory  @default(other)
  status          EntityStatus     @default(wait)
  parentId        String?        @map("parent_id")
  address         String?
  contactPerson   String?        @map("contact_person")
  contactEmail    String?        @map("contact_email")
  contactPhone    String?        @map("contact_phone")
  isShipowner     Boolean        @default(false) @map("is_shipowner")
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  parent    Company?  @relation("CompanyHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Company[] @relation("CompanyHierarchy")
  vessels   Vessel[]
  employees Employee[]
  projects  Project[]

  @@index([parentId])
  @@index([status])
  @@index([deletedAt])
  @@index([officeChangedAt])
  @@map("companies")
}

model Vessel {
  id              String         @id @default(cuid())
  companyId       String         @map("company_id")
  code            String
  name            String
  imoNumber       String?        @unique @map("imo_number")
  flag            String?
  vesselType      String?        @map("vessel_type")
  callSign        String?        @map("call_sign")
  grossTonnage    Float?         @map("gross_tonnage")
  yearBuilt       Int?           @map("year_built")
  status          EntityStatus   @default(active)
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeVessels   EmployeeVessel[]
  projects          Project[]        @relation("ProjectVessel")
  dryDockProjects   DryDockProject[]
  vesselJobs        DdVesselJob[]
  technicalProfile  VesselTechnicalProfile?

  nextDryDockDue    DateTime?        @map("next_dry_dock_due")
  lastDryDockDate   DateTime?        @map("last_dry_dock_date")
  classSociety      String?          @map("class_society")
  readinessScore    Int?             @map("readiness_score")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
  @@index([deletedAt])
  @@index([officeChangedAt])
  @@map("vessels")
}

model Employee {
  id              String         @id @default(cuid())
  companyId       String         @map("company_id")
  employeeCode    String         @unique @map("employee_code")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  email           String         @unique
  phone           String?
  designation     String?
  department      String?
  status          EntityStatus   @default(wait)
  roleId          String?        @map("role_id")
  userId          String?        @unique @map("user_id")
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role            Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  vesselAssignments EmployeeVessel[]

  @@index([companyId])
  @@index([status])
  @@index([deletedAt])
  @@index([officeChangedAt])
  @@map("employees")
}

model EmployeeVessel {
  id            String    @id @default(cuid())
  employeeId    String    @map("employee_id")
  vesselId      String    @map("vessel_id")
  assignedAt    DateTime  @default(now()) @map("assigned_at")
  isWatchKeeper Boolean   @default(false) @map("is_watch_keeper")
  signOffDate   DateTime? @map("sign_off_date")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  vessel   Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@unique([employeeId, vesselId])
  @@index([vesselId])
  @@map("employee_vessels")
}

model Organization {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  users    User[]
  roles    Role[]
  projects Project[]

  @@index([deletedAt])
  @@index([officeChangedAt])
  @@map("organizations")
}

/// System role catalog (organizationId null) or company-cloned roles.
model Role {
  id              String         @id @default(cuid())
  /// Spreadsheet Role ID (1, 2, … 39). Globally unique for system catalog rows.
  roleNo          Int?           @unique @map("role_no")
  code            String
  name            String
  userType        RbacUserType   @map("user_type")
  hierarchyLevel  Int            @map("hierarchy_level")
  sortOrder       Int            @default(0) @map("sort_order")
  designation     String?
  department      String?
  description     String?
  isSystem        Boolean        @default(true) @map("is_system")
  organizationId  String?        @map("organization_id")
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]
  employees       Employee[]

  @@unique([organizationId, code])
  @@index([userType, hierarchyLevel])
  @@index([deletedAt])
  @@index([officeChangedAt])
  @@map("roles")
}

model Permission {
  id          String     @id @default(cuid())
  key         String     @unique
  module      String
  resource    String?
  appSurface  AppSurface? @map("app_surface")
  description String?
  sortOrder   Int        @default(0) @map("sort_order")

  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id              String         @id @default(cuid())
  organizationId  String?        @map("organization_id")
  loginId         String?        @unique @map("login_id")
  email           String
  passwordHash    String?        @map("password_hash")
  displayName     String         @map("display_name")
  status          UserStatus     @default(invited)
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")
  lastLoginAt     DateTime?      @map("last_login_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization    Organization?            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  permissionOverrides UserPermissionOverride[]
  employeeProfile Employee?

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([deletedAt])
  @@index([officeChangedAt])
  @@map("users")
}

model UserRole {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  roleId          String         @map("role_id")
  scopeType       RbacScopeType  @default(organization) @map("scope_type")
  scopeId         String?        @map("scope_id")
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([roleId])
  @@index([scopeType, scopeId])
  @@index([deletedAt])
  @@map("user_roles")
}

/// Per-user grant/deny on top of role permissions (company policy overrides).
model UserPermissionOverride {
  id           String  @id @default(cuid())
  userId       String  @map("user_id")
  permissionId String  @map("permission_id")
  granted      Boolean @default(true)
  conditions   Json    @default("{}")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permission_overrides")
}

model Project {
  id              String         @id @default(cuid())
  organizationId  String?        @map("organization_id")
  companyId       String?        @map("company_id")
  name            String
  vesselName      String?        @map("vessel_name")
  referenceCode   String?        @map("reference_code")
  /// Links to vessels.id when registered; used for sync scope.
  vesselId        String?        @map("vessel_id")
  currency        String         @default("USD")
  shipyardDays    Int?           @map("shipyard_days")
  dryDockDays     Int?           @map("dry_dock_days")
  cprDays         Int?           @map("cpr_days")
  status          ProjectStatus  @default(draft)
  notes           String?
  scopeLocales    ScopeLocale[]  @default([en, zh, ja]) @map("scope_locales")
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  specLines         SpecLine[]
  yardInvites       YardInvite[]
  compareSnapshots  CompareSnapshot[]
  categories        ProjectCategory[]
  organization      Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  company           Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  vessel            Vessel?           @relation("ProjectVessel", fields: [vesselId], references: [id], onDelete: SetNull)
  dryDockProjects   DryDockProject[]  @relation("DryDockTenderLink")
  yardWorkProject   YardWorkProject?

  @@index([organizationId])
  @@index([companyId])
  @@index([vesselId])
  @@index([officeChangedAt])
  @@index([deletedAt])
  @@map("projects")
}

model SpecLine {
  id                String         @id @default(cuid())
  projectId         String         @map("project_id")
  bucket            String
  sortOrder         Int            @map("sort_order")
  lineCode          String?        @map("line_code")
  descriptionEn     String         @map("description_en")
  descriptionZh     String?        @map("description_zh")
  descriptionJa     String?        @map("description_ja")
  unit              String?
  defaultQty        Float?         @map("default_qty")
  scopeDays         Float?         @map("scope_days")
  scopeAreaM2       Float?         @map("scope_area_m2")
  scopeNotes        String?        @map("scope_notes")
  ownerLocked       Boolean        @default(true) @map("owner_locked")
  allowDiscount     Boolean        @default(true) @map("allow_discount")
  maxDiscountPct    Float?         @map("max_discount_pct")
  referenceUnitRate Float?         @map("reference_unit_rate")
  calcRule          String         @map("calc_rule")
  calcParams        Json           @default("{}") @map("calc_params")
  serviceDefId      String?        @map("service_def_id")
  isOptional        Boolean        @default(false) @map("is_optional")
  originNode        SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt   DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt    DateTime?      @map("relay_changed_at")
  deletedAt         DateTime?      @map("deleted_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quoteLines QuoteLine[]
  workshopJobs WorkshopJob[]

  @@index([projectId, sortOrder])
  @@index([officeChangedAt])
  @@index([deletedAt])
  @@map("spec_lines")
}

model ProjectCategory {
  id              String         @id @default(cuid())
  projectId       String         @map("project_id")
  categoryNo      String         @map("category_no")
  slug            String
  name            String
  shortcut        String
  sortOrder       Int            @map("sort_order")
  isSystem        Boolean        @default(false) @map("is_system")
  originNode      SyncOriginNode @default(office) @map("origin_node")
  officeChangedAt DateTime       @default(now()) @map("office_changed_at")
  relayChangedAt  DateTime?      @map("relay_changed_at")
  deletedAt       DateTime?      @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@unique([projectId, categoryNo])
  @@unique([projectId, shortcut])
  @@index([projectId, sortOrder])
  @@index([officeChangedAt])
  @@index([deletedAt])
  @@map("project_categories")
}

/// Company-wide master catalog — copied into new tender projects as spec lines.
model MasterSpecLine {
  id                String   @id @default(cuid())
  bucket            String
  sortOrder         Int      @map("sort_order")
  lineCode          String?  @unique @map("line_code")
  descriptionEn     String   @map("description_en")
  descriptionZh     String?  @map("description_zh")
  descriptionJa     String?  @map("description_ja")
  unit              String?
  defaultQty        Float?   @map("default_qty")
  scopeDays         Float?   @map("scope_days")
  scopeAreaM2       Float?   @map("scope_area_m2")
  scopeNotes        String?  @map("scope_notes")
  allowDiscount     Boolean  @default(true) @map("allow_discount")
  maxDiscountPct    Float?   @map("max_discount_pct")
  referenceUnitRate Float?   @map("reference_unit_rate")
  calcRule          String   @map("calc_rule")
  calcParams        Json     @default("{}") @map("calc_params")
  serviceDefId      String?  @map("service_def_id")
  isOptional        Boolean  @default(false) @map("is_optional")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([bucket, sortOrder])
  @@index([isActive])
  @@map("master_spec_lines")
}

enum YardWorkProjectStatus {
  planning
  execution
  completed
  on_hold
}

enum WorkshopJobStatus {
  not_started
  in_progress
  completed
  blocked
  awaiting_owner
  awaiting_class
  awaiting_material
}

enum JobPriority {
  critical
  high
  normal
  low
}

model YardWorkProject {
  id            String                @id @default(cuid())
  projectId     String                @unique @map("project_id")
  yardCompanyId String?               @map("yard_company_id")
  status        YardWorkProjectStatus @default(planning)
  plannedStart  DateTime?             @map("planned_start")
  plannedFinish DateTime?             @map("planned_finish")
  actualStart   DateTime?             @map("actual_start")
  actualFinish  DateTime?             @map("actual_finish")
  notes         String?
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs    WorkshopJob[]

  dailyProgress   YardDailyProgress[]
  delayEntries    YardDelayEntry[]
  permitEntries   YardPermitEntry[]
  inspectionEntries YardInspectionEntry[]
  clarifications  YardClarification[]
  variations      YardVariationEntry[]
  attachments     YardJobAttachment[]

  @@map("yard_work_projects")
}

model WorkshopJob {
  id                    String            @id @default(cuid())
  yardWorkProjectId     String            @map("yard_work_project_id")
  workshopSlug          String            @map("workshop_slug")
  jobCode               String?           @map("job_code")
  jobTitle              String            @map("job_title")
  vesselArea            String?           @map("vessel_area")
  priority              JobPriority       @default(normal)
  status                WorkshopJobStatus @default(not_started)
  plannedStart          DateTime?         @map("planned_start")
  plannedFinish         DateTime?         @map("planned_finish")
  actualStart           DateTime?         @map("actual_start")
  actualFinish          DateTime?         @map("actual_finish")
  progressPct           Float             @default(0) @map("progress_pct")
  manpowerRequired      Int?              @map("manpower_required")
  equipmentRequired     String?           @map("equipment_required")
  materialRequired      String?           @map("material_required")
  permitRequired        String?           @map("permit_required")
  classHoldPoint        Boolean           @default(false) @map("class_hold_point")
  ownerApprovalRequired Boolean           @default(false) @map("owner_approval_required")
  blockingDependency    String?           @map("blocking_dependency")
  delayReason           String?           @map("delay_reason")
  remarks               String?
  isCriticalPath        Boolean           @default(false) @map("is_critical_path")
  isVariation           Boolean           @default(false) @map("is_variation")
  specLineId            String?           @map("spec_line_id")
  sortOrder             Int               @default(0) @map("sort_order")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  yardWorkProject YardWorkProject           @relation(fields: [yardWorkProjectId], references: [id], onDelete: Cascade)
  specLine        SpecLine?                 @relation(fields: [specLineId], references: [id], onDelete: SetNull)
  predecessors    WorkshopJobDependency[]   @relation("JobSuccessor")
  successors      WorkshopJobDependency[]   @relation("JobPredecessor")
  dailyProgress   YardDailyProgress[]
  delayEntries    YardDelayEntry[]
  permitEntries   YardPermitEntry[]
  inspectionEntries YardInspectionEntry[]
  clarifications  YardClarification[]
  variations      YardVariationEntry[]
  attachments     YardJobAttachment[]

  @@index([yardWorkProjectId, workshopSlug])
  @@index([status])
  @@map("workshop_jobs")
}

model WorkshopJobDependency {
  id               String @id @default(cuid())
  successorJobId   String @map("successor_job_id")
  predecessorJobId String @map("predecessor_job_id")
  lagDays          Int    @default(0) @map("lag_days")

  successor   WorkshopJob @relation("JobSuccessor", fields: [successorJobId], references: [id], onDelete: Cascade)
  predecessor WorkshopJob @relation("JobPredecessor", fields: [predecessorJobId], references: [id], onDelete: Cascade)

  @@unique([successorJobId, predecessorJobId])
  @@map("workshop_job_dependencies")
}

enum YardRegisterStatus {
  open
  in_progress
  resolved
  closed
}

enum YardClarificationStatus {
  open
  awaiting_owner
  awaiting_class
  resolved
}

enum YardPermitType {
  hot_work
  enclosed_space
  height_work
  other
}

enum YardInspectionResult {
  pending
  pass
  fail
  conditional
}

enum YardAttachmentType {
  photo
  document
  drawing
  certificate
}

enum YardAttachmentVisibility {
  internal
  owner
  class
}

model YardDailyProgress {
  id                String   @id @default(cuid())
  yardWorkProjectId String   @map("yard_work_project_id")
  workshopJobId     String?  @map("workshop_job_id")
  reportDate        DateTime @map("report_date")
  progressPct       Float?   @map("progress_pct")
  manpowerCount     Int?     @map("manpower_count")
  remarks           String?
  updatedBy         String?  @map("updated_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  yardWorkProject YardWorkProject @relation(fields: [yardWorkProjectId], references: [id], onDelete: Cascade)
  workshopJob     WorkshopJob?    @relation(fields: [workshopJobId], references: [id], onDelete: SetNull)

  @@index([yardWorkProjectId, reportDate])
  @@map("yard_daily_progress")
}

model YardDelayEntry {
  id                String             @id @default(cuid())
  yardWorkProjectId String             @map("yard_work_project_id")
  workshopJobId     String?            @map("workshop_job_id")
  delayReason       String             @map("delay_reason")
  impactDays        Int?               @map("impact_days")
  ownerAction       String?            @map("owner_action")
  status            YardRegisterStatus @default(open)
  sinceDate         DateTime?          @map("since_date")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  yardWorkProject YardWorkProject @relation(fields: [yardWorkProjectId], references: [id], onDelete: Cascade)
  workshopJob     WorkshopJob?    @relation(fields: [workshopJobId], references: [id], onDelete: SetNull)

  @@index([yardWorkProjectId, status])
  @@map("yard_delay_entries")
}

model YardPermitEntry {
  id                String             @id @default(cuid())
  yardWorkProjectId String             @map("yard_work_project_id")
  workshopJobId     String?            @map("workshop_job_id")
  permitNo          String?            @map("permit_no")
  permitType        YardPermitType     @default(other) @map("permit_type")
  validFrom         DateTime?          @map("valid_from")
  validTo           DateTime?          @map("valid_to")
  safetyOfficer     String?            @map("safety_officer")
  status            YardRegisterStatus @default(open)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  yardWorkProject YardWorkProject @relation(fields: [yardWorkProjectId], references: [id], onDelete: Cascade)
  workshopJob     WorkshopJob?    @relation(fields: [workshopJobId], references: [id], onDelete: SetNull)

  @@index([yardWorkProjectId, status])
  @@map("yard_permit_entries")
}

model YardInspectionEntry {
  id                String               @id @default(cuid())
  yardWorkProjectId String               @map("yard_work_project_id")
  workshopJobId     String?              @map("workshop_job_id")
  holdPoint         String?              @map("hold_point")
  inspector         String?
  plannedDate       DateTime?            @map("planned_date")
  completedDate     DateTime?            @map("completed_date")

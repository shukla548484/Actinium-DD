  spareMappings          JobSpareMapping[]

  @@index([templateCategory])
  @@index([measurementSetId])
  @@index([checklistId])
  @@index([approvalWorkflowId])
  @@index([activeFlag])
  @@map("job_dynamic_templates")
}

